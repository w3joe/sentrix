# ── Anthropic API ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
SANDBOXV2_MAX_TOKENS=4096

# ── Simulation parameters ─────────────────────────────────────────────────────
SANDBOXV2_AGENT_COUNT=6
SANDBOXV2_TASK_INTERVAL=30
SANDBOXV2_AGENT_JITTER=5
SANDBOXV2_A2A_PROBABILITY=0.5

# ── Paths ─────────────────────────────────────────────────────────────────────
SANDBOXV2_RUN_DIR=sandbox_runs
# BRIDGE_DB_PATH=           # leave unset to use default bridge_db location

# ── Cluster ───────────────────────────────────────────────────────────────────
SANDBOXV2_CLUSTER_ID=cluster-1
SANDBOXV2_CLUSTER_NAME=SandboxV2 Host
