# Eval output artifacts (generated charts, logs, raw results — not committed)
# Leading / anchors to patrolswarm/ root — does NOT match eval/eval_output/
/eval_output/

# eval/eval_output: ignore generated files, commit the processed dataset only
eval/eval_output/*
!eval/eval_output/pii_agent_swarm/
eval/eval_output/pii_agent_swarm/*
!eval/eval_output/pii_agent_swarm/agent_swarm_docs.parquet
!eval/eval_output/pii_agent_swarm/selected_doc_types.json

