# Patrol Swarm — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ─── Brev NIM endpoints ───────────────────────────────────────────────────────
# Nemotron 3 Nano (30B / 3B active) — patrol agents
BREV_NANO_ENDPOINT=https://<your-brev-nano-deployment>.brev.dev/v1

# Nemotron 3 Super (~100B / 10B active) — swarm orchestrator
BREV_SUPER_ENDPOINT=https://<your-brev-super-deployment>.brev.dev/v1

# Brev API key (shared for both endpoints)
BREV_API_KEY=your_brev_api_key_here

# ─── Model names (override if your Brev deployment uses different names) ──────
NANO_MODEL=nvidia/nemotron-mini-4b-instruct
SUPER_MODEL=nvidia/nemotron-super-49b-v1

# ─── Token budget (increase if JSON is truncated, especially with --thinking) ──
# NANO_MAX_TOKENS=2048
# SUPER_MAX_TOKENS=2048

# ─── Anthropic Claude (set PATROL_DEPLOYMENT=claude to use) ──────────────────
# ANTHROPIC_API_KEY=your_anthropic_api_key
# CLAUDE_MODEL=claude-3-5-haiku-20241022   # default; or claude-sonnet-4-6, etc.

# ─── Local LM Studio (set PATROL_DEPLOYMENT=local to use) ─────────────────────
# LOCAL_ENDPOINT=http://localhost:1234/v1
# LOCAL_API_KEY=lm-studio
# LOCAL_PATROL_MODEL=nvidia_nvidia-nemotron-nano-9b-v2@q4_k_s
# LOCAL_ORCHESTRATOR_MODEL=nvidia_nvidia-nemotron-nano-9b-v2@q4_k_s
# LOCAL_TOOL_CHOICE=none   # set to "none" if model doesn't support tool-calling

# ─── Thinking / chain-of-thought (or use --thinking CLI flag) ─────────────────
# PATROL_THINKING=1

# ─── LangSmith tracing (free tier) ───────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=patrol-swarm
LANGCHAIN_API_KEY=your_langsmith_api_key_here
